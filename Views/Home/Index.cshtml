@using WebBanNuocMVC.Data
@{
    ViewData["Title"] = "Home";
    Layout = "_CustomerLayout";
    var featuredProducts = ViewBag.FeaturedProducts as List<Drink> ?? new List<Drink>();
    var latestProducts = ViewBag.LatestProducts as List<Drink> ?? new List<Drink>();
    var totalProducts = ViewBag.TotalProducts != null ? (int)ViewBag.TotalProducts : 0;
    var totalCategories = ViewBag.TotalCategories != null ? (int)ViewBag.TotalCategories : 0;
    var averagePrice = ViewBag.AveragePrice != null ? (decimal)ViewBag.AveragePrice : 0;
}

<div class="container-fluid p-0 mb-5">
    <div id="blog-carousel" class="carousel slide overlay-bottom" data-ride="carousel">
        <div class="carousel-inner">
            <div class="carousel-item active">
                <img class="w-100" src="~/img/carousel-1.jpg" alt="Image">
                <div class="carousel-caption d-flex flex-column align-items-center justify-content-center text-center px-3">
                    <span class="hero-kicker mb-3">Fresh drinks, clearer browsing</span>
                    <h1 class="display-3 text-white m-0">Coffee data shown the right way</h1>
                    <p class="text-white mt-3 mb-4 hero-copy">Browse products, categories, pricing, and recent items in a cleaner storefront that feels less like a placeholder and more like a real shop.</p>
                    <div>
                        <a asp-controller="Shop" asp-action="Index" class="btn btn-primary py-3 px-4 mr-2">Shop now</a>
                        <a asp-controller="Shop" asp-action="Menu" class="btn btn-outline-light py-3 px-4">View menu</a>
                    </div>
                </div>
            </div>
            <div class="carousel-item">
                <img class="w-100" src="~/img/carousel-2.jpg" alt="Image">
                <div class="carousel-caption d-flex flex-column align-items-center justify-content-center text-center px-3">
                    <span class="hero-kicker mb-3">Useful at a glance</span>
                    <h1 class="display-3 text-white m-0">Products, categories, and prices</h1>
                    <p class="text-white mt-3 mb-4 hero-copy">The homepage now highlights the catalog itself so users can understand what the shop offers before they click deeper.</p>
                    <div>
                        <a asp-controller="Customer" asp-action="MyOrders" class="btn btn-primary py-3 px-4 mr-2">My orders</a>
                        <a asp-controller="Cart" asp-action="Index" class="btn btn-outline-light py-3 px-4">Go to cart</a>
                    </div>
                </div>
            </div>
        </div>
        <a class="carousel-control-prev" href="#blog-carousel" data-slide="prev">
            <span class="carousel-control-prev-icon"></span>
        </a>
        <a class="carousel-control-next" href="#blog-carousel" data-slide="next">
            <span class="carousel-control-next-icon"></span>
        </a>
    </div>
</div>

<div class="container-fluid pb-5">
    <div class="container">
        <div class="row stats-grid">
            <div class="col-md-4 mb-4">
                <div class="insight-card">
                    <div class="insight-label">Products</div>
                    <div class="insight-value">@totalProducts</div>
                    <p class="insight-text mb-0">Catalog items currently shown in the storefront.</p>
                </div>
            </div>
            <div class="col-md-4 mb-4">
                <div class="insight-card">
                    <div class="insight-label">Categories</div>
                    <div class="insight-value">@totalCategories</div>
                    <p class="insight-text mb-0">Grouped menu sections for easier exploration.</p>
                </div>
            </div>
            <div class="col-md-4 mb-4">
                <div class="insight-card">
                    <div class="insight-label">Average price</div>
                    <div class="insight-value">@averagePrice.ToString("N0")đ</div>
                    <p class="insight-text mb-0">A quick pricing reference for first-time visitors.</p>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container-fluid py-5">
    <div class="container">
        <div class="section-title">
            <h4 class="text-primary text-uppercase" style="letter-spacing: 5px;">Catalog overview</h4>
            <h1 class="display-4">What users can understand immediately</h1>
        </div>
        <div class="row align-items-stretch">
            <div class="col-lg-6 mb-4">
                <div class="surface-card h-100">
                    <h3 class="section-card-title">Why this layout works better</h3>
                    <div class="data-bullet-list">
                        <div><i class="fa fa-check-circle mr-2"></i>Shows counts for products and categories instead of decorative-only content.</div>
                        <div><i class="fa fa-check-circle mr-2"></i>Highlights recent products so the homepage reflects real data.</div>
                        <div><i class="fa fa-check-circle mr-2"></i>Connects users quickly to shop, menu, cart, and orders.</div>
                    </div>
                    <a asp-controller="Shop" asp-action="Index" class="btn btn-primary mt-4 px-4 py-2">Browse full catalog</a>
                </div>
            </div>
            <div class="col-lg-6 mb-4">
                <div class="surface-card h-100">
                    <h3 class="section-card-title">Newest additions</h3>
                    @if (latestProducts.Any())
                    {
                        @foreach (var item in latestProducts)
                        {
                            <div class="mini-product-row">
                                <img src="@Url.Content(string.IsNullOrEmpty(item.Image) ? "~/img/menu-1.jpg" : item.Image)" alt="@item.DrinkName" />
                                <div>
                                    <div class="mini-product-name">@item.DrinkName</div>
                                    <div class="mini-product-meta">@(item.Category?.CategoryName ?? "Other") • @((item.Price ?? 0).ToString("N0"))đ</div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <p class="mb-0">No recent items available.</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@if (featuredProducts.Any())
{
    <div class="container-fluid pt-5">
        <div class="container">
            <div class="section-title">
                <h4 class="text-primary text-uppercase" style="letter-spacing: 5px;">Featured selection</h4>
                <h1 class="display-4">Products with clearer data presentation</h1>
            </div>
            <div class="row">
                @foreach (var drink in featuredProducts)
                {
                    <div class="col-lg-3 col-md-6 mb-4">
                        <div class="home-product-card h-100">
                            <img class="home-product-image" src="@Url.Content(string.IsNullOrEmpty(drink.Image) ? "~/img/menu-1.jpg" : drink.Image)" alt="@drink.DrinkName">
                            <div class="home-product-body">
                                <div class="product-chip">@(drink.Category?.CategoryName ?? "Other")</div>
                                <h4 class="home-product-title">@drink.DrinkName</h4>
                                <p class="home-product-desc">@(string.IsNullOrWhiteSpace(drink.Description) ? "Delicious drink" : drink.Description)</p>
                                <div class="d-flex align-items-center justify-content-between mt-auto">
                                    <span class="home-product-price">@((drink.Price ?? 0).ToString("N0"))đ</span>
                                    <a asp-controller="Shop" asp-action="ProductDetail" asp-route-id="@drink.DrinkId" class="btn btn-outline-primary btn-sm">View</a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}

<style>
    .hero-kicker {
        display: inline-block;
        padding: 8px 16px;
        border-radius: 999px;
        background: rgba(218, 159, 91, 0.18);
        border: 1px solid rgba(218, 159, 91, 0.35);
        color: #fff;
        font-weight: 600;
        letter-spacing: 0.8px;
        text-transform: uppercase;
    }

    .hero-copy {
        max-width: 760px;
        font-size: 17px;
        line-height: 1.8;
    }

    .insight-card,
    .surface-card,
    .home-product-card {
        background: #2c1f14;
        border-radius: 18px;
        box-shadow: 0 14px 32px rgba(0, 0, 0, 0.12);
    }

    .insight-card {
        padding: 28px;
        height: 100%;
        border: 1px solid rgba(218, 159, 91, 0.16);
    }

    .insight-label {
        color: rgba(255,255,255,0.7);
        font-size: 13px;
        letter-spacing: 1px;
        text-transform: uppercase;
        margin-bottom: 10px;
    }

    .insight-value {
        color: #fff;
        font-size: 34px;
        font-weight: 700;
        margin-bottom: 8px;
    }

    .insight-text,
    .data-bullet-list div,
    .mini-product-meta,
    .home-product-desc {
        color: rgba(255,255,255,0.72);
    }

    .surface-card {
        padding: 30px;
        color: #fff;
        border: 1px solid rgba(255,255,255,0.06);
    }

    .section-card-title {
        color: #fff;
        margin-bottom: 18px;
        font-weight: 700;
    }

    .data-bullet-list div {
        padding: 12px 0;
        border-bottom: 1px solid rgba(255,255,255,0.08);
    }

    .mini-product-row {
        display: flex;
        gap: 14px;
        align-items: center;
        padding: 12px 0;
        border-bottom: 1px solid rgba(255,255,255,0.08);
    }

    .mini-product-row img {
        width: 64px;
        height: 64px;
        border-radius: 14px;
        object-fit: cover;
    }

    .mini-product-name,
    .home-product-title {
        color: #fff;
        font-weight: 700;
    }

    .home-product-card {
        overflow: hidden;
        display: flex;
        flex-direction: column;
        height: 100%;
    }

    .home-product-image {
        width: 100%;
        height: 220px;
        object-fit: cover;
    }

    .home-product-body {
        padding: 22px;
        display: flex;
        flex-direction: column;
        height: 100%;
    }

    .product-chip {
        display: inline-block;
        background: rgba(218, 159, 91, 0.16);
        color: #da9f5b;
        border-radius: 999px;
        padding: 6px 12px;
        font-size: 12px;
        font-weight: 700;
        margin-bottom: 12px;
        text-transform: uppercase;
        letter-spacing: 0.8px;
    }

    .home-product-price {
        color: #da9f5b;
        font-size: 24px;
        font-weight: 700;
    }
</style>

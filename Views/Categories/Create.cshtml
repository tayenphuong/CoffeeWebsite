@model WebBanNuocMVC.Data.Category

@{
    ViewData["Title"] = "Create Category";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <h2 style="color: #3a2c1f; font-weight: bold;">
                    <i class="fas fa-plus-circle mr-2" style="color: #da9f5b;"></i>
                    Create New Category
                </h2>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="fas fa-arrow-left mr-2"></i>Back to List
                </a>
            </div>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card shadow-sm">
                <div class="card-header" style="background: linear-gradient(135deg, #3a2c1f 0%, #2c1f14 100%); border: none;">
                    <h5 class="m-0 font-weight-bold" style="color: #da9f5b;">
                        <i class="fas fa-list mr-2"></i>Category Information
                    </h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                        
                        <div class="form-group">
                            <label asp-for="CategoryName" class="font-weight-bold">
                                <i class="fas fa-tag mr-2" style="color: #da9f5b;"></i>Category Name
                            </label>
                            <input asp-for="CategoryName" class="form-control form-control-lg" placeholder="Enter category name (e.g., Coffee, Tea, Juice)" />
                            <span asp-validation-for="CategoryName" class="text-danger"></span>
                            <small class="form-text text-muted">This will be used to organize your products</small>
                        </div>

                        <hr class="my-4">

                        <div class="form-group mb-0">
                            <div class="d-flex justify-content-between">
                                <a asp-action="Index" class="btn btn-secondary btn-lg px-5">
                                    <i class="fas fa-times mr-2"></i>Cancel
                                </a>
                                <button type="submit" class="btn btn-lg px-5" style="background-color: #da9f5b; color: white; border: none;">
                                    <i class="fas fa-save mr-2"></i>Create Category
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

<style>
    .form-control:focus {
        border-color: #da9f5b;
        box-shadow: 0 0 0 0.2rem rgba(218, 159, 91, 0.25);
    }
    
    .btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 8px rgba(0,0,0,0.2);
        transition: all 0.3s;
    }
</style>

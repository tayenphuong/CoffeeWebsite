@{
    ViewData["Title"] = "KOFFEE - Access Denied";
    Layout = "_CustomerLayout";
}


<div class="container-fluid page-header mb-5 position-relative overlay-bottom">
    <div class="d-flex flex-column align-items-center justify-content-center pt-0 pt-lg-5" style="min-height: 400px">
        <h1 class="display-4 mb-3 mt-0 mt-lg-5 text-white text-uppercase">Access Denied</h1>
    </div>
</div>



<div class="container-fluid py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-6 text-center">
                <div class="bg-secondary rounded p-5">
                    <i class="fas fa-lock fa-5x text-primary mb-4"></i>
                    <h1 class="display-4 text-white mb-3">Access Denied</h1>
                    <p class="text-white mb-4">You don't have permission to access this page.</p>
                    <a asp-controller="Home" asp-action="Index" class="btn btn-primary font-weight-bold py-3 px-5">Go to Home</a>
                </div>
            </div>
        </div>
    </div>
</div>


@model WebBanNuocMVC.Data.Drink

@{
    ViewData["Title"] = "Edit Product";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <h2 style="color: #3a2c1f; font-weight: bold;">
                    <i class="fas fa-edit mr-2" style="color: #da9f5b;"></i>
                    Edit Product
                </h2>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="fas fa-arrow-left mr-2"></i>Back to List
                </a>
            </div>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-header" style="background: linear-gradient(135deg, #3a2c1f 0%, #2c1f14 100%); border: none;">
                    <h5 class="m-0 font-weight-bold" style="color: #da9f5b;">
                        <i class="fas fa-coffee mr-2"></i>Product Information
                    </h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit" method="post" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                        <input type="hidden" asp-for="DrinkId" />
                        
                        <div class="form-group">
                            <label asp-for="DrinkName" class="font-weight-bold">
                                <i class="fas fa-tag mr-2" style="color: #da9f5b;"></i>Product Name
                            </label>
                            <input asp-for="DrinkName" class="form-control form-control-lg" />
                            <span asp-validation-for="DrinkName" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="CategoryId" class="font-weight-bold">
                                <i class="fas fa-list mr-2" style="color: #da9f5b;"></i>Category
                            </label>
                            <select asp-for="CategoryId" class="form-control form-control-lg" asp-items="ViewBag.CategoryId"></select>
                            <span asp-validation-for="CategoryId" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="Price" class="font-weight-bold">
                                <i class="fas fa-dollar-sign mr-2" style="color: #da9f5b;"></i>Price (VND)
                            </label>
                            <input asp-for="Price" class="form-control form-control-lg" />
                            <span asp-validation-for="Price" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="Description" class="font-weight-bold">
                                <i class="fas fa-align-left mr-2" style="color: #da9f5b;"></i>Description
                            </label>
                            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label class="font-weight-bold">
                                <i class="fas fa-image mr-2" style="color: #da9f5b;"></i>Product Image
                            </label>
                            
                            @if (!string.IsNullOrEmpty(Model.Image))
                            {
                                <div class="mb-3 p-3" style="background: #f8f9fa; border-radius: 8px; border: 2px solid #dee2e6;">
                                    <p class="mb-2 font-weight-bold text-success">
                                        <i class="fas fa-check-circle mr-2"></i>Current Image
                                    </p>
                                    <img src="@Url.Content(Model.Image)" alt="Current product image" 
                                         class="img-thumbnail" 
                                         style="max-width: 250px; max-height: 250px; display: block; margin: 0 auto;"
                                         onerror="this.src='@Url.Content("~/img/menu-1.jpg")'; this.alt='Image not found';">
                                </div>
                            }
                            
                            <div class="custom-file mb-2">
                                <input type="file" class="custom-file-input" id="imageFile" name="imageFile" accept="image/*" onchange="previewImage(this)">
                                <label class="custom-file-label" for="imageFile">Choose new image (optional)...</label>
                            </div>
                            <small class="form-text text-muted">
                                <i class="fas fa-info-circle mr-1"></i>Upload a new image to replace the current one (JPG, PNG, GIF)
                            </small>
                            
                            <div id="imagePreview" class="mt-3 p-3" style="display:none; background: #e7f5ff; border-radius: 8px; border: 2px solid #339af0;">
                                <p class="mb-2 font-weight-bold text-primary">
                                    <i class="fas fa-eye mr-2"></i>New Image Preview
                                </p>
                                <img id="preview" src="#" alt="New image preview" 
                                     class="img-thumbnail" 
                                     style="max-width: 250px; max-height: 250px; display: block; margin: 0 auto;">
                            </div>
                            
                            <input type="hidden" asp-for="Image" />
                        </div>

                        <hr class="my-4">

                        <div class="form-group mb-0">
                            <div class="d-flex justify-content-between">
                                <a asp-action="Index" class="btn btn-secondary btn-lg px-5">
                                    <i class="fas fa-times mr-2"></i>Cancel
                                </a>
                                <button type="submit" class="btn btn-lg px-5" style="background-color: #da9f5b; color: white; border: none;">
                                    <i class="fas fa-save mr-2"></i>Save Changes
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <script>
        function previewImage(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                var fileName = input.files[0].name;
                
                $(input).next('.custom-file-label').html(fileName);
                
                reader.onload = function(e) {
                    $('#preview').attr('src', e.target.result);
                    $('#imagePreview').show();
                }
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}

<style>
    .form-control:focus {
        border-color: #da9f5b;
        box-shadow: 0 0 0 0.2rem rgba(218, 159, 91, 0.25);
    }
    
    .btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 8px rgba(0,0,0,0.2);
        transition: all 0.3s;
    }
    
    /* Custom file input styling */
    .custom-file-label::after {
        background: linear-gradient(135deg, #da9f5b 0%, #c88a45 100%);
        color: white;
        border: none;
    }
</style>

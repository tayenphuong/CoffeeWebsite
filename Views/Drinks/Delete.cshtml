@model WebBanNuocMVC.Data.Drink

@{
    ViewData["Title"] = "Delete Product";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <h2 style="color: #dc3545; font-weight: bold;">
                    <i class="fas fa-exclamation-triangle mr-2"></i>
                    Delete Product
                </h2>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="fas fa-arrow-left mr-2"></i>Back to List
                </a>
            </div>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="alert alert-danger" role="alert">
                <h4 class="alert-heading">
                    <i class="fas fa-exclamation-circle mr-2"></i>Are you sure you want to delete this product?
                </h4>
                <p class="mb-0">This action cannot be undone. All data related to this product will be permanently deleted.</p>
            </div>

            <div class="card shadow-sm">
                <div class="card-header" style="background: linear-gradient(135deg, #dc3545 0%, #c82333 100%); border: none;">
                    <h5 class="m-0 font-weight-bold text-white">
                        <i class="fas fa-coffee mr-2"></i>Product Information
                    </h5>
                </div>
                <div class="card-body p-4">
                    <div class="row mb-4">
                        <div class="col-md-4 text-center">
                            @if (!string.IsNullOrEmpty(Model.Image))
                            {
                                <img src="@Url.Content(Model.Image)" alt="@Model.DrinkName" 
                                     class="img-thumbnail" 
                                     style="max-width: 200px; max-height: 200px;"
                                     onerror="this.src='@Url.Content("~/img/menu-1.jpg")';">
                            }
                            else
                            {
                                <img src="@Url.Content("~/img/menu-1.jpg")" alt="No image" class="img-thumbnail" style="max-width: 200px;">
                            }
                        </div>
                        <div class="col-md-8">
                            <dl class="row mb-0">
                                <dt class="col-sm-4"><i class="fas fa-tag mr-2 text-danger"></i>Product Name:</dt>
                                <dd class="col-sm-8 font-weight-bold">@Model.DrinkName</dd>

                                <dt class="col-sm-4"><i class="fas fa-list mr-2 text-danger"></i>Category:</dt>
                                <dd class="col-sm-8">
                                    <span class="badge badge-secondary">@(Model.Category?.CategoryName ?? "N/A")</span>
                                </dd>

                                <dt class="col-sm-4"><i class="fas fa-dollar-sign mr-2 text-danger"></i>Price:</dt>
                                <dd class="col-sm-8">
                                    <span class="font-weight-bold" style="color: #da9f5b; font-size: 18px;">
                                        @((Model.Price ?? 0).ToString("N0"))đ
                                    </span>
                                </dd>

                                <dt class="col-sm-4"><i class="fas fa-align-left mr-2 text-danger"></i>Description:</dt>
                                <dd class="col-sm-8">@(Model.Description ?? "No description")</dd>
                            </dl>
                        </div>
                    </div>

                    <hr class="my-4">

                    <form asp-action="Delete">
                        <input type="hidden" asp-for="DrinkId" />
                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-secondary btn-lg px-5">
                                <i class="fas fa-times mr-2"></i>Cancel
                            </a>
                            <button type="submit" class="btn btn-danger btn-lg px-5" onclick="return confirm('Are you absolutely sure you want to delete this product?');">
                                <i class="fas fa-trash-alt mr-2"></i>Delete Product
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 8px rgba(0,0,0,0.2);
        transition: all 0.3s;
    }
</style>

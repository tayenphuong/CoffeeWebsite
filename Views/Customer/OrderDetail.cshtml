@model WebBanNuocMVC.Data.Order

@{
    ViewData["Title"] = "KOFFEE - Order Details";
    Layout = "_CustomerLayout";
}


<div class="container-fluid page-header mb-5 position-relative overlay-bottom">
    <div class="d-flex flex-column align-items-center justify-content-center pt-0 pt-lg-5" style="min-height: 400px">
        <h1 class="display-4 mb-3 mt-0 mt-lg-5 text-white text-uppercase">Order #@Model.OrderId</h1>
        <div class="d-inline-flex mb-lg-5">
            <p class="m-0 text-white"><a class="text-white" asp-controller="Home" asp-action="Index">Home</a></p>
            <p class="m-0 text-white px-2">/</p>
            <p class="m-0 text-white"><a class="text-white" asp-action="MyOrders">My Orders</a></p>
            <p class="m-0 text-white px-2">/</p>
            <p class="m-0 text-white">Order #@Model.OrderId</p>
        </div>
    </div>
</div>



<div class="container-fluid py-5">
    <div class="container">
        <div class="row">
            <div class="col-lg-8">
                <div class="bg-secondary rounded p-4 mb-4">
                    <h4 class="text-white mb-4">Order Information</h4>
                    <div class="row text-white">
                        <div class="col-md-6">
                            <p><strong>Order ID:</strong> #@Model.OrderId</p>
                            <p><strong>Order Date:</strong> @Model.OrderDate?.ToString("dd/MM/yyyy HH:mm")</p>
                            <p><strong>Status:</strong> 
                                <span class="badge badge-@(Model.Status == "Completed" || Model.Status == "Paid" ? "success" : Model.Status == "Pending" ? "warning" : "info")">
                                    @Model.Status
                                </span>
                            </p>
                        </div>
                        <div class="col-md-6">
                            <p><strong>Customer:</strong> @Model.Customer?.CustomerName</p>
                            <p><strong>Phone:</strong> @Model.Customer?.Phone</p>
                            <p><strong>Email:</strong> @Model.Customer?.Email</p>
                        </div>
                    </div>
                </div>

                <div class="bg-secondary rounded p-4 mb-4">
                    <h4 class="text-white mb-4">Order Items</h4>
                    <div class="table-responsive">
                        <table class="table table-dark">
                            <thead>
                                <tr>
                                    <th>Product</th>
                                    <th>Price</th>
                                    <th>Quantity</th>
                                    <th>Subtotal</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.OrderDetails)
                                {
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <img src="@(string.IsNullOrEmpty(item.Drink?.Image) ? "~/img/menu-1.jpg" : item.Drink.Image)" 
                                                     alt="@item.Drink?.DrinkName" 
                                                     class="rounded mr-3"
                                                     style="width: 50px; height: 50px; object-fit: cover;">
                                                <span>@item.Drink?.DrinkName</span>
                                            </div>
                                        </td>
                                        <td>@((item.UnitPrice ?? 0).ToString("N0"))đ</td>
                                        <td>@item.Quantity</td>
                                        <td>@(((item.UnitPrice ?? 0) * (item.Quantity ?? 0)).ToString("N0"))đ</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="bg-secondary rounded p-4">
                    <h4 class="text-white mb-3">Delivery Address</h4>
                    <p class="text-white mb-0">
                        <i class="fa fa-map-marker-alt mr-2"></i>
                        @Model.Customer?.Address
                    </p>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="bg-secondary rounded p-4 mb-4">
                    <h4 class="text-white mb-4">Order Summary</h4>
                    
                    <div class="d-flex justify-content-between text-white mb-3">
                        <span>Subtotal:</span>
                        <span>@(((Model.TotalAmount ?? 0) - 20000).ToString("N0"))đ</span>
                    </div>
                    
                    <div class="d-flex justify-content-between text-white mb-3">
                        <span>Shipping:</span>
                        <span>20,000đ</span>
                    </div>
                    
                    <hr class="bg-white">
                    
                    <div class="d-flex justify-content-between text-white mb-4">
                        <h5>Total:</h5>
                        <h5 class="text-primary">@((Model.TotalAmount ?? 0).ToString("N0"))đ</h5>
                    </div>
                </div>

                <div class="bg-secondary rounded p-4">
                    <h5 class="text-white mb-3">Need Help?</h5>
                    <p class="text-white-50 mb-3">If you have any questions about your order, please contact us.</p>
                    <a href="#" class="btn btn-primary btn-block">
                        <i class="fa fa-phone mr-2"></i>Contact Support
                    </a>
                </div>

                <div class="mt-4">
                    <a asp-action="MyOrders" class="btn btn-secondary btn-block">
                        <i class="fa fa-arrow-left mr-2"></i>Back to Orders
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>


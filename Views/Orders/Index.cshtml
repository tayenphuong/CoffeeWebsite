@model IEnumerable<WebBanNuocMVC.Data.Order>

@{
    ViewData["Title"] = "Orders Management";
    Layout = "_AdminLayout";
    var currentStatus = (ViewBag.CurrentStatus as string ?? "all").ToLower();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 style="color: #3a2c1f; font-weight: bold; margin: 0;">
        <i class="fas fa-shopping-cart mr-2" style="color: #da9f5b;"></i>
        Orders Management
    </h2>
    <a asp-action="Create" class="btn btn-create">
        <i class="fas fa-plus-circle mr-2"></i>Create New Order
    </a>
</div>

<div class="status-filter-bar mb-4">
    <a asp-action="Index" asp-route-status="all"
       class="status-filter-btn @(currentStatus == "all" ? "active dark" : "")">
        Tất cả
    </a>

    <a asp-action="Index" asp-route-status="pendingpayment"
       class="status-filter-btn @(currentStatus == "pendingpayment" ? "active secondary" : "")">
        Chờ thanh toán
    </a>

    <a asp-action="Index" asp-route-status="pending"
       class="status-filter-btn @(currentStatus == "pending" ? "active warning" : "")">
        Đang chờ
    </a>

    <a asp-action="Index" asp-route-status="completed"
       class="status-filter-btn @(currentStatus == "completed" ? "active success" : "")">
        Hoàn tất
    </a>

    <a asp-action="Index" asp-route-status="cancelled"
       class="status-filter-btn @(currentStatus == "cancelled" ? "active danger" : "")">
        Đã hủy
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0 modern-table">
                <thead>
                    <tr>
                        <th>Customer</th>
                        <th>Order Date</th>
                        <th>Total Amount</th>
                        <th>Status</th>
                        <th>Table</th>
                        <th style="width: 200px; text-align: center;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            var rawStatus = (item.Status ?? "").Trim();
                            var normalizedStatus = rawStatus.ToLower() switch
                            {
                                "pendingpayment" => "pendingpayment",
                                "pending payment" => "pendingpayment",
                                "completed" => "completed",
                                "paid" => "completed",
                                "processing" => "pending",
                                "pending" => "pending",
                                "cancelled" => "cancelled",
                                "canceled" => "cancelled",
                                _ => "pending"
                            };

                            var statusText = normalizedStatus switch
                            {
                                "pendingpayment" => "PENDING PAYMENT",
                                "completed" => "COMPLETED",
                                "cancelled" => "CANCELLED",
                                _ => "PENDING"
                            };

                            var statusClass = normalizedStatus switch
                            {
                                "pendingpayment" => "badge-status-secondary",
                                "completed" => "badge-status-success",
                                "cancelled" => "badge-status-danger",
                                _ => "badge-status-warning"
                            };

                            var statusIcon = normalizedStatus switch
                            {
                                "pendingpayment" => "fas fa-credit-card",
                                "completed" => "fas fa-check-circle",
                                "cancelled" => "fas fa-times-circle",
                                _ => "fas fa-clock"
                            };

                            <tr>
                                <td>
                                    <i class="fas fa-user-circle mr-1" style="color: #da9f5b;"></i>
                                    @(item.Customer?.CustomerName ?? "Guest")
                                </td>
                                <td>
                                    <i class="far fa-calendar mr-1 text-muted"></i>
                                    @item.OrderDate?.ToString("dd/MM/yyyy HH:mm")
                                </td>
                                <td>
                                    <strong style="color: #28a745;">@((item.TotalAmount ?? 0).ToString("N0"))đ</strong>
                                </td>
                                <td>
                                    <span class="badge badge-status @statusClass">
                                        <i class="@statusIcon mr-1"></i>@statusText
                                    </span>
                                </td>
                                <td>
                                    @if (item.Table != null)
                                    {
                                        <span class="badge badge-pill badge-secondary">
                                            <i class="fas fa-chair mr-1"></i>Table @item.Table.TableId
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="btn-group-modern">
                                        <a asp-action="Details" asp-route-id="@item.OrderId" class="btn-action btn-action-info" title="View Details">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.OrderId" class="btn-action btn-action-warning" title="Edit">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.OrderId" class="btn-action btn-action-danger" title="Delete">
                                            <i class="fas fa-trash-alt"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-4 text-muted">
                                Không có đơn hàng thuộc trạng thái này
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .btn-create {
        background: linear-gradient(135deg, #da9f5b 0%, #c88a45 100%);
        color: white;
        border: none;
        padding: 12px 24px;
        border-radius: 8px;
        font-weight: 600;
        transition: all 0.3s ease;
        box-shadow: 0 4px 6px rgba(218, 159, 91, 0.3);
    }

        .btn-create:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 12px rgba(218, 159, 91, 0.4);
            color: white;
            text-decoration: none;
        }

    .status-filter-bar {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
    }

    .status-filter-btn {
        display: inline-block;
        padding: 10px 18px;
        border-radius: 999px;
        text-decoration: none;
        font-weight: 600;
        border: 1px solid #ddd;
        color: #3a2c1f;
        background: #fff;
        transition: all 0.25s ease;
    }

        .status-filter-btn:hover {
            text-decoration: none;
            color: #3a2c1f;
            transform: translateY(-1px);
        }

        .status-filter-btn.active.dark {
            background: #2c1f14;
            color: #fff;
            border-color: #2c1f14;
        }

        .status-filter-btn.active.secondary {
            background: #6c757d;
            color: #fff;
            border-color: #6c757d;
        }

        .status-filter-btn.active.warning {
            background: #ffc107;
            color: #3a2c1f;
            border-color: #ffc107;
        }

        .status-filter-btn.active.success {
            background: #28a745;
            color: #fff;
            border-color: #28a745;
        }

        .status-filter-btn.active.danger {
            background: #dc3545;
            color: #fff;
            border-color: #dc3545;
        }

    .modern-table {
        font-size: 0.95rem;
    }

        .modern-table thead th {
            background: linear-gradient(135deg, #3a2c1f 0%, #2c1f14 100%);
            color: #da9f5b;
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.85rem;
            letter-spacing: 0.5px;
            padding: 16px;
            border: none;
        }

        .modern-table tbody td {
            padding: 16px;
            vertical-align: middle;
            border-bottom: 1px solid #e9ecef;
        }

        .modern-table tbody tr:hover {
            background-color: #f8f9fa;
        }

    .badge-status {
        padding: 8px 16px;
        border-radius: 6px;
        font-weight: 600;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .badge-status-success {
        background: linear-gradient(135deg, #28a745 0%, #218838 100%);
        color: white;
    }

    .badge-status-warning {
        background: linear-gradient(135deg, #ffc107 0%, #e0a800 100%);
        color: #3a2c1f;
    }

    .badge-status-secondary {
        background: linear-gradient(135deg, #6c757d 0%, #5a6268 100%);
        color: white;
    }

    .badge-status-danger {
        background: linear-gradient(135deg, #dc3545 0%, #c82333 100%);
        color: white;
    }

    .btn-group-modern {
        display: flex;
        gap: 8px;
        justify-content: center;
    }

    .btn-action {
        width: 36px;
        height: 36px;
        border-radius: 8px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s ease;
        border: none;
        color: white;
        text-decoration: none;
        font-size: 0.9rem;
    }

        .btn-action:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 8px rgba(0,0,0,0.2);
            color: white;
            text-decoration: none;
        }

    .btn-action-info {
        background: linear-gradient(135deg, #17a2b8 0%, #138496 100%);
    }

    .btn-action-warning {
        background: linear-gradient(135deg, #ffc107 0%, #e0a800 100%);
    }

    .btn-action-danger {
        background: linear-gradient(135deg, #dc3545 0%, #c82333 100%);
    }

    .card {
        border: none;
        border-radius: 12px;
        overflow: hidden;
    }
</style>
@model WebBanNuocMVC.Data.Order
@{ ViewData["Title"] = "Order Details"; }

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12 d-flex justify-content-between align-items-center">
            <h2 style="color: #3a2c1f; font-weight: bold;"><i class="fas fa-info-circle mr-2" style="color: #da9f5b;"></i>Order Details</h2>
            <div>
                <a asp-action="Edit" asp-route-id="@Model.OrderId" class="btn btn-warning mr-2"><i class="fas fa-edit mr-2"></i>Edit</a>
                <a asp-action="Index" class="btn btn-secondary"><i class="fas fa-arrow-left mr-2"></i>Back</a>
            </div>
        </div>
    </div>
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-header" style="background: linear-gradient(135deg, #3a2c1f 0%, #2c1f14 100%); border: none;">
                    <h5 class="m-0 font-weight-bold" style="color: #da9f5b;"><i class="fas fa-shopping-cart mr-2"></i>Order Information</h5>
                </div>
                <div class="card-body p-4">
                    <div class="detail-row"><div class="detail-label"><i class="fas fa-hashtag mr-2" style="color: #da9f5b;"></i>Order ID</div><div class="detail-value">#@Model.OrderId</div></div>
                    <div class="detail-row"><div class="detail-label"><i class="fas fa-calendar mr-2" style="color: #da9f5b;"></i>Order Date</div><div class="detail-value">@Model.OrderDate?.ToString("dd/MM/yyyy HH:mm")</div></div>
                    <div class="detail-row"><div class="detail-label"><i class="fas fa-user mr-2" style="color: #da9f5b;"></i>Customer</div><div class="detail-value">@(Model.Customer?.CustomerName ?? "N/A")</div></div>
                    <div class="detail-row"><div class="detail-label"><i class="fas fa-chair mr-2" style="color: #da9f5b;"></i>Table</div><div class="detail-value">Table #@(Model.Table?.TableId ?? 0)</div></div>
                    <div class="detail-row"><div class="detail-label"><i class="fas fa-user-tie mr-2" style="color: #da9f5b;"></i>Staff</div><div class="detail-value">@(Model.Account?.Username ?? "N/A")</div></div>
                    <div class="detail-row"><div class="detail-label"><i class="fas fa-info-circle mr-2" style="color: #da9f5b;"></i>Status</div><div class="detail-value"><span class="badge badge-@(Model.Status == "Completed" ? "success" : Model.Status == "Cancelled" ? "danger" : "warning") badge-lg">@Model.Status</span></div></div>
                    <div class="detail-row"><div class="detail-label"><i class="fas fa-money-bill-wave mr-2" style="color: #da9f5b;"></i>Total Amount</div><div class="detail-value"><span style="font-size:24px;font-weight:bold;color:#da9f5b;">@((Model.TotalAmount ?? 0).ToString("N0"))đ</span></div></div>
                </div>
            </div>
        </div>
    </div>
</div>
<style>.detail-row{padding:16px 0;border-bottom:1px solid #dee2e6;}.detail-row:last-child{border-bottom:none;}.detail-label{font-weight:600;color:#495057;margin-bottom:8px;font-size:14px;text-transform:uppercase;}.detail-value{font-size:16px;color:#212529;}.btn:hover{transform:translateY(-2px);box-shadow:0 4px 8px rgba(0,0,0,0.2);transition:all 0.3s;}</style>

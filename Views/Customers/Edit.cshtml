@model WebBanNuocMVC.Data.Customer

@{
    ViewData["Title"] = "Edit Customer";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <h2 style="color: #3a2c1f; font-weight: bold;">
                    <i class="fas fa-user-edit mr-2" style="color: #da9f5b;"></i>
                    Edit Customer
                </h2>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="fas fa-arrow-left mr-2"></i>Back to List
                </a>
            </div>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-header" style="background: linear-gradient(135deg, #3a2c1f 0%, #2c1f14 100%); border: none;">
                    <h5 class="m-0 font-weight-bold" style="color: #da9f5b;">
                        <i class="fas fa-user mr-2"></i>Customer Information
                    </h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                        <input type="hidden" asp-for="CustomerId" />
                        
                        <div class="form-group">
                            <label asp-for="CustomerName" class="font-weight-bold">
                                <i class="fas fa-id-card mr-2" style="color: #da9f5b;"></i>Customer Name
                            </label>
                            <input asp-for="CustomerName" class="form-control form-control-lg" />
                            <span asp-validation-for="CustomerName" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label asp-for="Phone" class="font-weight-bold">
                                        <i class="fas fa-phone mr-2" style="color: #da9f5b;"></i>Phone Number
                                    </label>
                                    <input asp-for="Phone" class="form-control form-control-lg" />
                                    <span asp-validation-for="Phone" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label asp-for="Email" class="font-weight-bold">
                                        <i class="fas fa-envelope mr-2" style="color: #da9f5b;"></i>Email Address
                                    </label>
                                    <input asp-for="Email" class="form-control form-control-lg" />
                                    <span asp-validation-for="Email" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="form-group">
                            <label asp-for="Address" class="font-weight-bold">
                                <i class="fas fa-map-marker-alt mr-2" style="color: #da9f5b;"></i>Address
                            </label>
                            <textarea asp-for="Address" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="Address" class="text-danger"></span>
                        </div>

                        <hr class="my-4">

                        <div class="form-group mb-0">
                            <div class="d-flex justify-content-between">
                                <a asp-action="Index" class="btn btn-secondary btn-lg px-5">
                                    <i class="fas fa-times mr-2"></i>Cancel
                                </a>
                                <button type="submit" class="btn btn-lg px-5" style="background-color: #da9f5b; color: white; border: none;">
                                    <i class="fas fa-save mr-2"></i>Save Changes
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

<style>
    .form-control:focus {
        border-color: #da9f5b;
        box-shadow: 0 0 0 0.2rem rgba(218, 159, 91, 0.25);
    }
    
    .btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 8px rgba(0,0,0,0.2);
        transition: all 0.3s;
    }
</style>

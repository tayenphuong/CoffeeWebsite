@model WebBanNuocMVC.Data.Customer
@{ ViewData["Title"] = "Delete Customer"; }

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12 d-flex justify-content-between align-items-center">
            <h2 style="color: #dc3545; font-weight: bold;"><i class="fas fa-exclamation-triangle mr-2"></i>Delete Customer</h2>
            <a asp-action="Index" class="btn btn-secondary"><i class="fas fa-arrow-left mr-2"></i>Back</a>
        </div>
    </div>
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="alert alert-danger"><h4 class="alert-heading"><i class="fas fa-exclamation-circle mr-2"></i>Are you sure?</h4><p class="mb-0">This will permanently delete the customer and all related data.</p></div>
            <div class="card shadow-sm">
                <div class="card-header" style="background: linear-gradient(135deg, #dc3545 0%, #c82333 100%); border: none;">
                    <h5 class="m-0 font-weight-bold text-white"><i class="fas fa-user mr-2"></i>Customer Information</h5>
                </div>
                <div class="card-body p-4">
                    <dl class="row mb-4">
                        <dt class="col-sm-3"><i class="fas fa-id-card mr-2 text-danger"></i>Name:</dt><dd class="col-sm-9 font-weight-bold">@Model.CustomerName</dd>
                        <dt class="col-sm-3"><i class="fas fa-phone mr-2 text-danger"></i>Phone:</dt><dd class="col-sm-9">@Model.Phone</dd>
                        <dt class="col-sm-3"><i class="fas fa-envelope mr-2 text-danger"></i>Email:</dt><dd class="col-sm-9">@Model.Email</dd>
                        <dt class="col-sm-3"><i class="fas fa-map-marker-alt mr-2 text-danger"></i>Address:</dt><dd class="col-sm-9">@Model.Address</dd>
                    </dl>
                    <hr class="my-4">
                    <form asp-action="Delete">
                        <input type="hidden" asp-for="CustomerId" />
                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-secondary btn-lg px-5"><i class="fas fa-times mr-2"></i>Cancel</a>
                            <button type="submit" class="btn btn-danger btn-lg px-5" onclick="return confirm('Delete permanently?');"><i class="fas fa-trash-alt mr-2"></i>Delete</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
<style>.btn:hover{transform:translateY(-2px);box-shadow:0 4px 8px rgba(0,0,0,0.2);transition:all 0.3s;}</style>

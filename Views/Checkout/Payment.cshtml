@model WebBanNuocMVC.Models.ViewModels.CheckoutViewModel
@{
    ViewData["Title"] = "KOFFEE - Payment";
    Layout = "_CustomerLayout";
    var cart = (WebBanNuocMVC.Models.Cart.ShoppingCart)ViewBag.Cart;
    var checkoutInfo = (WebBanNuocMVC.Models.ViewModels.CheckoutViewModel)ViewBag.CheckoutInfo;
    var returnToAdmin = Context.Request.Query["returnToAdmin"].ToString() == "true" ? "true" : null;
}

<div class="container-fluid page-header mb-5 position-relative overlay-bottom">
    <div class="d-flex flex-column align-items-center justify-content-center pt-0 pt-lg-5" style="min-height: 400px">
        <h1 class="display-4 mb-3 mt-0 mt-lg-5 text-white text-uppercase">Payment</h1>
        <div class="d-inline-flex mb-lg-5">
            <p class="m-0 text-white"><a class="text-white" asp-controller="Home" asp-action="Index" asp-route-returnToAdmin="@returnToAdmin">Home</a></p>
            <p class="m-0 text-white px-2">/</p>
            <p class="m-0 text-white"><a class="text-white" asp-controller="Cart" asp-action="Index" asp-route-returnToAdmin="@returnToAdmin">Cart</a></p>
            <p class="m-0 text-white px-2">/</p>
            <p class="m-0 text-white">Payment</p>
        </div>
    </div>
</div>

<div class="container-fluid py-5">
    <div class="container">
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                <strong>Error!</strong> @TempData["Error"]
                <button type="button" class="close" data-dismiss="alert">&times;</button>
            </div>
        }

        <div class="row">
            <div class="col-lg-8">
                <div class="bg-secondary rounded p-5">
                    <h4 class="text-white mb-4">Select Payment Method</h4>

                    <form asp-action="ProcessPayment" method="post" id="paymentForm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="returnToAdmin" value="@returnToAdmin" />

                        <div class="payment-option mb-4 p-4 bg-dark rounded border-primary-custom">
                            <div class="custom-control custom-radio d-flex align-items-center">
                                <input type="radio" id="cod" name="paymentMethod" value="COD" class="custom-control-input">
                                <label class="custom-control-label text-white w-100" for="cod">
                                    <div class="d-flex align-items-start ml-2">
                                        <div class="mr-3">
                                            <i class="fas fa-money-bill-wave text-success" style="font-size: 1.5rem;"></i>
                                        </div>
                                        <div>
                                            <h5 class="text-white mb-1">Thanh toán tiền mặt (COD)</h5>
                                            <p class="text-white-50 mb-0 small">Thanh toán khi nhận hàng trực tiếp.</p>
                                        </div>
                                    </div>
                                </label>
                            </div>
                        </div>

                        <div class="payment-option mb-4 p-4 bg-dark rounded opacity-75">
                            <div class="custom-control custom-radio">
                                <input type="radio" id="paypal" name="paymentMethod" value="PayPal" class="custom-control-input" disabled>
                                <label class="custom-control-label text-white" for="paypal">
                                    <h5 class="mb-1 text-muted">
                                        <i class="fab fa-paypal text-primary mr-2"></i>PayPal
                                        <span class="badge badge-warning ml-2" style="font-size: 10px;">Soon</span>
                                    </h5>
                                    <p class="text-white-50 mb-0 small">Thanh toán an toàn qua cổng PayPal quốc tế.</p>
                                </label>
                            </div>
                        </div>

                        <div class="payment-option mb-4 p-4 bg-dark rounded border-primary-custom" id="vnpay-container">
                            <div class="custom-control custom-radio d-flex align-items-center">
                                <input type="radio" id="vnpay" name="paymentMethod" value="VNPay" class="custom-control-input">
                                <label class="custom-control-label text-white w-100" for="vnpay">
                                    <div class="d-flex align-items-start ml-2">
                                        <div class="mr-3">
                                            <i class="fas fa-credit-card text-info" style="font-size: 1.5rem;"></i>
                                        </div>
                                        <div>
                                            <h5 class="text-white mb-1">Thanh toán qua VNPay</h5>
                                            <p class="text-white-50 mb-0 small">Thanh toán nhanh qua QR Code, Ứng dụng ngân hàng hoặc Thẻ nội địa.</p>
                                        </div>
                                    </div>
                                </label>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between mt-5">
                            <a asp-controller="Checkout" asp-action="Index" asp-route-returnToAdmin="@returnToAdmin" class="btn btn-outline-light py-3 px-4">
                                <i class="fa fa-arrow-left mr-2"></i>Back to Checkout
                            </a>
                            <button type="submit" class="btn btn-primary py-3 px-5 font-weight-bold">
                                <i class="fa fa-check mr-2"></i>CONFIRM ORDER
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="bg-secondary rounded p-4 mb-4">
                    <h4 class="text-white mb-4 border-bottom pb-3">Order Summary</h4>
                    <div class="summary-items mb-3">
                        @if (cart != null) {
                            @foreach (var item in cart.Items) {
                                <div class="d-flex justify-content-between text-white mb-2">
                                    <span class="text-white-50 small">@item.DrinkName x@item.Quantity</span>
                                    <span class="small">@item.Subtotal.ToString("N0")đ</span>
                                </div>
                            }
                        }
                    </div>

                    <hr class="border-secondary">
                    <div class="d-flex justify-content-between text-white mb-2">
                        <span>Subtotal:</span>
                        <span>@cart?.TotalAmount.ToString("N0")đ</span>
                    </div>
                    @if (cart?.DiscountAmount > 0) {
                        <div class="d-flex justify-content-between text-success mb-2">
                            <span>Discount:</span>
                            <span>-@cart.DiscountAmount.ToString("N0")đ</span>
                        </div>
                    }
                    <div class="d-flex justify-content-between text-white mb-3">
                        <span>Shipping:</span>
                        <span>20,000đ</span>
                    </div>

                    <div class="p-3 rounded bg-dark border-dashed">
                        <div class="d-flex justify-content-between align-items-center">
                            <h5 class="text-white m-0">Total:</h5>
                            <h4 class="text-primary m-0 font-weight-bold">
                                @(( (cart?.FinalAmount ?? 0) + 20000).ToString("N0"))đ
                            </h4>
                        </div>
                    </div>
                </div>

                @if (checkoutInfo != null) {
                    <div class="bg-secondary rounded p-4">
                        <h5 class="text-white mb-3 border-bottom pb-2">Shipping Information</h5>
                        <p class="text-white mb-1"><strong>@checkoutInfo.CustomerName</strong></p>
                        <p class="text-white-50 small mb-1"><i class="fa fa-phone mr-2"></i>@checkoutInfo.Phone</p>
                        <p class="text-white-50 small mb-0"><i class="fa fa-map-marker-alt mr-2"></i>@checkoutInfo.Address</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<style>
    .payment-option {
        border: 2px solid transparent;
        transition: all 0.3s ease;
        cursor: pointer;
    }
    .payment-option:hover:not(.opacity-75) {
        border-color: #da9f5b;
        background-color: #2b2118 !important;
    }
    .border-dashed {
        border: 1px dashed #da9f5b;
    }
    .opacity-75 {
        opacity: 0.6;
        cursor: not-allowed;
    }
    /* Style cho radio custom để đẹp hơn */
    .custom-control-input:checked ~ .custom-control-label::before {
        background-color: #da9f5b;
        border-color: #da9f5b;
    }
</style>